# --- Database — Neon PostgreSQL ---
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# --- Google Gemini AI ---
GEMINI_API_KEY="votre-cle-api-gemini"

# --- JWT Secret ---
JWT_SECRET="openssl rand -base64 32"

# --- Cron Secret (for auto-publishing scheduled posts) ---
CRON_SECRET="openssl rand -base64 32"

# --- LinkedIn OAuth ---
LINKEDIN_CLIENT_ID="votre-client-id"
LINKEDIN_CLIENT_SECRET="votre-client-secret"
LINKEDIN_REDIRECT_URI="https://autocontent.<votre-compte>.workers.dev/api/auth/linkedin/callback"

# --- Facebook / Instagram OAuth ---
FACEBOOK_APP_ID="votre-app-id"
