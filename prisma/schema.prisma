generator client {
  provider = "prisma-client"
  runtime = "cloudflare"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  name         String?
  password     String?
  authProvider AuthProvider @default(LOCAL)
  role         Role        @default(USER)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  workspaces WorkspaceMember[]
  comments   Comment[]
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum Role {
  USER
  ADMIN
}

model Workspace {
  id                   String   @id @default(cuid())
  name                 String
  onboardingCompleted  Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  members             WorkspaceMember[]
  brandKits           BrandKit[]
  campaigns           Campaign[]
  invitations         Invitation[]
  platformConnections PlatformConnection[]
  insights            ContentInsight[]
  documents           Document[]
  repurposeJobs       RepurposeJob[]
}

enum WorkspaceRole {
  OWNER
  EDITOR
  CLIENT
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole @default(EDITOR)
  createdAt   DateTime      @default(now())

  user      User      @relation(fields: [userId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
}

model BrandKit {
  id           String   @id @default(cuid())
  workspaceId  String
  name         String
  logoUrl      String?
  colors       Json?
  fonts        Json?
  toneOfVoice  String?
  doAndDonts   String?
  voiceSamples Json?
  bios         Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
}

model Campaign {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  description String?
  colorCode   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  contents  Content[]
}

model Document {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  content     Json?
  wordCount   Int      @default(0)
  tags        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model RepurposeJob {
  id           String   @id @default(cuid())
  workspaceId  String
  sourceText   String
  sourceTitle  String?
  targetPlatforms String
  results      Json?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Content {
  id            String   @id @default(cuid())
  campaignId    String
  sourceIdea    String
  status        Status   @default(DRAFT)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id])
  posts    Post[]
}

enum Status {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SCHEDULED
  PUBLISHED
  FAILED
}

model Post {
  id             String   @id @default(cuid())
  contentId      String
  platform       Platform
  body           String
  mediaUrls      Json?
  firstComment   String?
  scheduledAt    DateTime?
  publishedAt    DateTime?
  platformPostId String?
  status         Status   @default(DRAFT)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  content  Content   @relation(fields: [contentId], references: [id])
  comments Comment[]
  analytics PostAnalytics[]
}

model PostAnalytics {
  id          String   @id @default(cuid())
  postId      String
  impressions Int      @default(0)
  reach       Int      @default(0)
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)
  clicks      Int      @default(0)
  fetchedAt   DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, fetchedAt])
  @@index([postId])
}

enum Platform {
  LINKEDIN
  TWITTER
  INSTAGRAM
  FACEBOOK
  TIKTOK
  PINTEREST
  WORDPRESS
  MEDIUM
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  text      String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([postId])
}

model Invitation {
  id          String        @id @default(cuid())
  workspaceId String
  email       String
  token       String        @unique
  role        WorkspaceRole @default(EDITOR)
  createdAt   DateTime      @default(now())
  expiresAt   DateTime

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([token])
  @@index([email])
}

model PlatformConnection {
  id               String    @id @default(cuid())
  workspaceId      String
  platform         String
  accessToken      String
  refreshToken     String?
  tokenExpiresAt   DateTime?
  platformUserId   String?
  platformUserName String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, platform])
  @@index([platform])
}

model ContentInsight {
  id          String   @id @default(cuid())
  workspaceId String
  type        String
  platform    String?
  title       String
  description String
  data        Json?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([type])
}
